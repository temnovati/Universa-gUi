local function SafeTeleport(targetCFrame)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    if Options.GradualTP then
        local startCFrame = root.CFrame
        if root:FindFirstChild("FlyBV") then root.FlyBV.Velocity = Vector3.zero end
        local wasAnchored = root.Anchored
        root.Anchored = true
        for i = 1, Options.TPSteps do
            if not char or not char:FindFirstChild("HumanoidRootPart") then break end
            root.CFrame = startCFrame:Lerp(targetCFrame, i / Options.TPSteps)
            task.wait(Options.TPDelayMS / 1000)
        end
        if char and char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.Anchored = wasAnchored end
    else
        root.CFrame = targetCFrame
    end
end

