local function CreateDrawing(type, props) local obj = Drawing.new(type); for k, v in pairs(props) do obj[k] = v end; return obj end
local function GetBoundingBox(char)
    local cf, size = char:GetBoundingBox()
    local corners = {
        cf * CFrame.new(size.X/2, size.Y/2, size.Z/2).Position, cf * CFrame.new(-size.X/2, size.Y/2, size.Z/2).Position,
        cf * CFrame.new(size.X/2, -size.Y/2, size.Z/2).Position, cf * CFrame.new(-size.X/2, -size.Y/2, size.Z/2).Position,
        cf * CFrame.new(size.X/2, size.Y/2, -size.Z/2).Position, cf * CFrame.new(-size.X/2, size.Y/2, -size.Z/2).Position,
        cf * CFrame.new(size.X/2, -size.Y/2, -size.Z/2).Position, cf * CFrame.new(-size.X/2, -size.Y/2, -size.Z/2).Position
    }
    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local vis = false
    for _, c in ipairs(corners) do
        local sp, onScreen = Camera:WorldToViewportPoint(c)
        if onScreen then vis = true end
        minX, minY = math.min(minX, sp.X), math.min(minY, sp.Y); maxX, maxY = math.max(maxX, sp.X), math.max(maxY, sp.Y)
    end
    if vis then return Vector2.new(minX, minY), Vector2.new(maxX - minX, maxY - minY) end
    return nil, nil
end

local function UpdateESP(player)
    if not Drawings[player] then
        Drawings[player] = {
            Box = CreateDrawing("Square", {Visible = false, Thickness = 1, Filled = false}),
            Tracer = CreateDrawing("Line", {Visible = false, Thickness = 1}),
            HealthText = CreateDrawing("Text", {Visible = false, Size = 14, Center = true, Outline = true}),
            DistText = CreateDrawing("Text", {Visible = false, Size = 14, Center = true, Outline = true, Color = Color3.fromRGB(255, 255, 255)}),
            Bones = {}
        }
        for i = 1, 15 do table.insert(Drawings[player].Bones, CreateDrawing("Line", {Visible = false, Thickness = 1})) end
    end
    local d = Drawings[player]; local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart"); local hum = char and char:FindFirstChildOfClass("Humanoid")
    if char and root and hum and player ~= LocalPlayer and hum.Health > 0 then
        local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position); local dist = (root.Position - Camera.CFrame.Position).Magnitude
        if onScreen then
            if Options.ESP_Boxes then
                local pos, size = GetBoundingBox(char)
                if pos and size then d.Box.Size = size; d.Box.Position = pos; d.Box.Color = Options.ESPColor; d.Box.Visible = true else d.Box.Visible = false end
            else d.Box.Visible = false end
            if Options.ESP_Skeleton then
                local conns = SkeletonConnections[hum.RigType.Name] or SkeletonConnections.R6
                for i, bone in ipairs(d.Bones) do
                    local conn = conns[i]
                    if conn and char:FindFirstChild(conn[1]) and char:FindFirstChild(conn[2]) then
                        local s1, vis1 = Camera:WorldToViewportPoint(char[conn[1]].Position); local s2, vis2 = Camera:WorldToViewportPoint(char[conn[2]].Position)
                        if vis1 or vis2 then bone.From = Vector2.new(s1.X, s1.Y); bone.To = Vector2.new(s2.X, s2.Y); bone.Color = Options.ESPColor; bone.Visible = true else bone.Visible = false end
                    else bone.Visible = false end
                end
            else for _, bone in ipairs(d.Bones) do bone.Visible = false end end
            if Options.ESP_Tracers then d.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); d.Tracer.To = Vector2.new(rootPos.X, rootPos.Y); d.Tracer.Color = Options.ESPColor; d.Tracer.Visible = true else d.Tracer.Visible = false end
            if Options.ESP_Health then d.HealthText.Text = math.floor(hum.Health).." HP"; d.HealthText.Position = Vector2.new(rootPos.X, rootPos.Y - (2800/dist) - 15); d.HealthText.Color = Color3.fromRGB(255 - (hum.Health/hum.MaxHealth*255), hum.Health/hum.MaxHealth*255, 0); d.HealthText.Visible = true else d.HealthText.Visible = false end
            if Options.ESP_Distance then d.DistText.Text = math.floor(dist).."m"; d.DistText.Position = Vector2.new(rootPos.X, rootPos.Y + (2800/dist)); d.DistText.Visible = true else d.DistText.Visible = false end
        else
            d.Box.Visible = false; d.Tracer.Visible = false; d.HealthText.Visible = false; d.DistText.Visible = false; for _, bone in ipairs(d.Bones) do bone.Visible = false end
        end
    else
        d.Box.Visible = false; d.Tracer.Visible = false; d.HealthText.Visible = false; d.DistText.Visible = false; for _, bone in ipairs(d.Bones) do bone.Visible = false end
    end
end
RunService.RenderStepped:Connect(function() for _, p in pairs(Players:GetPlayers()) do UpdateESP(p) end end)
Players.PlayerRemoving:Connect(function(p)
    if Drawings[p] then Drawings[p].Box:Remove(); Drawings[p].Tracer:Remove(); Drawings[p].HealthText:Remove(); Drawings[p].DistText:Remove(); for _, b in ipairs(Drawings[p].Bones) do b:Remove() end; Drawings[p] = nil end
end)

-- [[ ГЛАВНЫЙ ЦИКЛ ]]
RunService.Stepped:Connect(function()
    local Char = LocalPlayer.Character; local Hum = Char and Char:FindFirstChildOfClass("Humanoid"); local Root = Char and Char:FindFirstChild("HumanoidRootPart")
    if Hum then
        Hum.WalkSpeed = Options.SpeedEnabled and Options.SpeedValue or 16
        if Options.JumpEnabled then Hum.UseJumpPower = true; Hum.JumpPower = Options.JumpValue; Hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true) else Hum.JumpPower = 50 end
    end
    if Char and Options.NoClip then for _, part in pairs(Char:GetDescendants()) do if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end end end
    
    local isFlying = Options.Fly or Options.FlyToolActive
    if Root then
        local bv = Root:FindFirstChild("FlyBV")
        if isFlying then
            if not bv then bv = Instance.new("BodyVelocity"); bv.Name = "FlyBV"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge); bv.Parent = Root end
            local Cam = workspace.CurrentCamera; local Dir = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then Dir += Cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then Dir -= Cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then Dir -= Cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then Dir += Cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then Dir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then Dir -= Vector3.new(0,1,0) end
            currentFlyVelocity = currentFlyVelocity:Lerp(Dir * Options.FlySpeed, Options.FlySmoothness); bv.Velocity = currentFlyVelocity
        else if bv then bv:Destroy() end end
    end
    
    if Options.FullBright then
        Lighting.Ambient = Color3.new(1, 1, 1); Lighting.OutdoorAmbient = Color3.new(1, 1, 1); Lighting.ColorShift_Bottom = Color3.new(1, 1, 1); Lighting.ColorShift_Top = Color3.new(1, 1, 1)
    else
        Lighting.Ambient = MapDefaults.Ambient; Lighting.OutdoorAmbient = MapDefaults.OutdoorAmbient; Lighting.ColorShift_Bottom = MapDefaults.ColorShift_Bottom; Lighting.ColorShift_Top = MapDefaults.ColorShift_Top
    end
end)

